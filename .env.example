# DashScope (Alibaba Cloud Model Studio) API key — get one at https://modelstudio.console.alibabacloud.com/
QWEN_API_KEY=sk-your-dashscope-api-key

# OpenAI-compatible endpoint for Qwen on Alibaba Cloud (international)
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model used by the agent society
QWEN_MODEL=qwen-plus

# Local server port (Alibaba Function Compute custom runtime expects 9000)
PORT=9000

# Set to 1 to run the full pipeline offline with canned agent responses (no API key needed)
MOCK_QWEN=0
